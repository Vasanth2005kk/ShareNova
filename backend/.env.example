# ─── Server ──────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/sharenova

# ─── Storage ───────────────────────────────────────────
STORAGE_DIR=storage

# ─── Security ────────────────────────────────────────────
BCRYPT_ROUNDS=12
SESSION_SECRET=change_me_to_a_random_32_char_string

# ─── Limits ──────────────────────────────────────────────
MAX_UPLOAD_BYTES=524288000

# ─── CORS ────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
